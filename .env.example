# MySQL
MYSQL_ROOT_PASSWORD=changeme

# rustfs (S3-compatible storage)
RUSTFS_ROOT_USER=fakekey
RUSTFS_ROOT_PASSWORD=fakesecret

# Setup (run 'make setup' once before first 'make run')
SETUP_COMPLETED=false

# Volume path (leave empty for named volumes on disk, set to /tmp/docker-volumes for tmpfs)
VOLUMES_PATH=

# Redpanda user (set to root when using tmpfs for volumes)
REDPANDA_USER=

# Redpanda (Kafka) retention settings
REDPANDA_RETENTION_BYTES=10485760    # 10MB per partition
REDPANDA_RETENTION_MS=3600000        # 1 hour
REDPANDA_LOG_SEGMENT_BYTES=10485760  # 10MB segment size

# Elasticsearch
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=entitybase

# Meilisearch
MEILISEARCH_HOST=meilisearch
MEILISEARCH_PORT=7700
MEILISEARCH_INDEX=entitybase

# Vitess Database
#VITESS_HOST="localhost"
#VITESS_PORT="3306"
#VITESS_DATABASE="entitybase"
#VITESS_USER="root"
#VITESS_PASSWORD=""

# Redpanda/Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENTITY_CHANGE_TOPIC=entitybase.entity_change
KAFKA_INCREMENTAL_RDF_TOPIC=incremental_rdf_diff
INCREMENTAL_RDF_ENABLED=false
INCREMENTAL_RDF_CONSUMER_GROUP=incremental-rdf-worker

# Version
VERSION_ENTITYBASE_BACKEND=v2026.4.8
VERSION_KAFKA2SSE_BACKEND=v2026.4.8
VERSION_KAFKA2SSE_FRONTEND=v2026.4.8
VERSION_ORCHESTRATOR_FRONTEND=v2026.4.8

# Logging
LOG_LEVEL=INFO

# API
API_PORT=8080
API_WORKERS=1

# Kafka2SSE
KAFKA2SSE_BACKEND_URL=http://localhost:8888

# Streaming
STREAMING_ENABLED=true
STREAMING_BACKEND=redpanda  # Currently only "redpanda" is supported
STREAMING_ENTITYCHANGE_VERSION=1.0.0
STREAMING_ENDORSECHANGE_VERSION=1.0.0
STREAMING_NEWTHANK_VERSION=1.0.0
STREAMING_ENTITY_CHANGE_VERSION=1.0.0

# S3 Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=fakekey
S3_SECRET_KEY=fakesecret
S3_BUCKET=testbucket

# S3 Versioning
S3_REVISION_VERSION=3.0.0
S3_STATEMENT_VERSION=1.0.0
S3_QUALIFIER_VERSION=1.0.0
S3_REFERENCE_VERSION=1.0.0
S3_SNAK_VERSION=1.0.0
S3_SITELINK_VERSION=1.0.0

# Application
ENTITY_JSON_VERSION=2.0.0
DANGLING_PROPERTY_ID=P6104
ENVIRONMENT=development
API_DESCRIPTION=
USER_AGENT=Entitybase/1.0
PYTHONPATH=src

# Frontend
VITE_HOST=http://localhost:5173
